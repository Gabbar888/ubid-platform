# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ubid
POSTGRES_USER=ubid
POSTGRES_PASSWORD=ubid_secret

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── OpenSearch ────────────────────────────────────────────────────────────────
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX=ubid-canonical-records

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ubid_neo4j_secret

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_SOURCE_RECORDS=ubid.source.records
KAFKA_TOPIC_ACTIVITY_EVENTS=ubid.events.activity
KAFKA_TOPIC_REVIEW_DECISIONS=ubid.review.decisions
KAFKA_TOPIC_QUARANTINE=ubid.quarantine
KAFKA_CONSUMER_GROUP=ubid-workers

# ── DuckDB event warehouse ─────────────────────────────────────────────────────
DUCKDB_PATH=/app/data/parquet/events.duckdb

# ── Model artefacts ───────────────────────────────────────────────────────────
MODEL_DIR=/app/data/models

# ── Linkage thresholds ────────────────────────────────────────────────────────
AUTO_LINK_THRESHOLD=0.95
REVIEW_THRESHOLD_LOW=0.55

# ── Activity engine ───────────────────────────────────────────────────────────
ACTIVITY_ALPHA=1.5
ACTIVE_SCORE_THRESHOLD=1.5
DORMANT_SCORE_THRESHOLD=0.4
NASCENT_HOLD_DAYS=90

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
